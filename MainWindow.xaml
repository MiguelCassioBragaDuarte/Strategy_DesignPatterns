<Controls:MetroWindow x:Class="SistemaDePagamentos_Strategy.MainWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
                      mc:Ignorable="d"
                      Title="Sistema de Pagamentos"
                      Height="400" Width="500"
                      WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <Border CornerRadius="10" Padding="20" Background="White">
            <StackPanel>

                <!-- TÍTULO -->
                <TextBlock Text="💳 Sistema de Pagamentos"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center"/>

                <!-- VALOR -->
                <TextBlock Text="Valor" FontWeight="SemiBold"/>
                <TextBox Name="txtValor"
                         Height="35"
                         Margin="0,5,0,10"
                         FontSize="14"
                         Controls:TextBoxHelper.Watermark="Digite o valor"/>

                <!-- PAGAMENTO -->
                <TextBlock Text="Forma de Pagamento" FontWeight="SemiBold"/>
                <ComboBox Name="cbPagamento"
                          Height="35"
                          Margin="0,5,0,20"
                          Controls:TextBoxHelper.Watermark="Selecione um método">
                    <ComboBoxItem Content="Pix"/>
                    <ComboBoxItem Content="Cartão"/>
                    <ComboBoxItem Content="Boleto"/>
                    <ComboBoxItem Content="Dinheiro"/>
                </ComboBox>

                <!-- BOTÕES -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                    <Button x:Name="btnPagar"
                            Content="Pagar"
                            Width="120"
                            Height="40"
                            Margin="5"
                            Click="BtnPagar_Click"/>

                    <Button x:Name="btnNovo"
                            Content="Novo"
                            Width="120"
                            Height="40"
                            Margin="5"
                            Click="BtnNovo_Click"
                            Visibility="Collapsed"/>

                </StackPanel>

            </StackPanel>
        </Border>

    </Grid>
</Controls:MetroWindow>