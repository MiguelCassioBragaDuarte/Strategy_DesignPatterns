<Window x:Class="SistemaDePagamentos_Strategy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SistemaDePagamentos_Strategy"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        <StackPanel>

            <TextBlock Text="Valor:"/>
            <TextBox Name="txtValor" Margin="0,5"/>

            <TextBlock Text="Forma de Pagamento:" Margin="0,10,0,0"/>
            <ComboBox Name="cbPagamento" Margin="0,5">
                <ComboBoxItem Content="Pix"/>
                <ComboBoxItem Content="Cartão"/>
                <ComboBoxItem Content="Boleto"/>
                <ComboBoxItem Content="Dinheiro"/>
            </ComboBox>

            <Button x:Name="btnPagar" Content="Pagar" Click="BtnPagar_Click" Margin="0,15,0,0"/>

            <Button x:Name="btnNovo" Content="Novo Pagamento" Click="BtnNovo_Click" Margin="0,5,0,0" Visibility="Collapsed"/>

            <TextBlock Name="txtResultado" Margin="0,10" TextWrapping="Wrap"/>

        </StackPanel>
    </Grid>
</Window>
